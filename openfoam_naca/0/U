FoamFile
{
    version     2.0;
    format      ascii;
    class       volVectorField;
    location    "0";
    object      U;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 1 -1 0 0 0 0];
internalField   uniform (30.0 0 0);
boundaryField
{
    farfield { type freestream; freestreamValue uniform (30.0 0 0); }
    airfoil { type noSlip; }
    frontAndBack { type empty; }
}
