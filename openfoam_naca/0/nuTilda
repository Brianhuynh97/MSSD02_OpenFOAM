FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      nuTilda;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -1 0 0 0 0];
internalField   uniform 4.5e-05;
boundaryField
{
    farfield { type freestream; freestreamValue uniform 4.5e-05; }
    airfoil { type fixedValue; value uniform 0; }
    frontAndBack { type empty; }
}
